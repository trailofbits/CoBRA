{
    "name": "CoBRA",
    "build": { "dockerfile": "Dockerfile" },
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                "llvm-vs-code-extensions.vscode-clangd"
            ],
            "settings": {
                "cmake.buildDirectory": "${workspaceFolder}/build",
                "cmake.configureArgs": [
                    "-DCMAKE_PREFIX_PATH=${workspaceFolder}/build-deps/install"
                ]
            }
        }
    },
    "postCreateCommand": "just deps",
    "remoteUser": "vscode"
}
