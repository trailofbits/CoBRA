        case 206: // 0x177e cost=6
            return Expr::BitwiseXor(Expr::BitwiseAnd(v(0), v(1)), Expr::BitwiseOr(Expr::BitwiseXor(v(2), v(3)), Expr::BitwiseXor(v(0), Expr::BitwiseXor(v(1), v(2)))));
        case 207: // 0x178e cost=5
            return Expr::BitwiseXor(v(2), Expr::BitwiseOr(Expr::BitwiseXor(v(0), v(1)), Expr::BitwiseXor(v(0), Expr::BitwiseXor(v(2), v(3)))));
        case 208: // 0x1796 cost=6
            return Expr::BitwiseXor(v(0), Expr::BitwiseOr(Expr::BitwiseXor(v(1), v(2)), Expr::BitwiseAnd(v(3), Expr::BitwiseNot(Expr::BitwiseXor(v(0), v(1))))));
        case 209: // 0x1798 cost=7
            return Expr::BitwiseXor(v(3), Expr::BitwiseOr(Expr::BitwiseAnd(v(0), v(1)), Expr::BitwiseAnd(v(2), Expr::BitwiseNot(Expr::BitwiseXor(v(0), Expr::BitwiseXor(v(1), v(3)))))));
        case 210: // 0x179a cost=7
            return Expr::BitwiseXor(v(0), Expr::BitwiseXor(v(3), Expr::BitwiseAnd(Expr::BitwiseXor(v(2), Expr::BitwiseAnd(v(0), v(3))), Expr::BitwiseXor(v(1), Expr::BitwiseXor(v(2), v(3))))));
        case 211: // 0x17ac cost=6
            return Expr::BitwiseXor(v(1), Expr::BitwiseXor(v(3), Expr::BitwiseAnd(Expr::BitwiseXor(v(0), v(1)), Expr::BitwiseXor(v(2), Expr::BitwiseAnd(v(1), v(3))))));
        case 212: // 0x17e8 cost=5
            return Expr::BitwiseXor(v(0), Expr::BitwiseXor(v(3), Expr::BitwiseAnd(Expr::BitwiseXor(v(0), v(2)), Expr::BitwiseXor(v(0), v(1)))));
        case 213: // 0x18e7 cost=5
            return Expr::BitwiseNot(Expr::BitwiseXor(v(3), Expr::BitwiseAnd(Expr::BitwiseXor(v(1), v(2)), Expr::BitwiseXor(v(0), v(2)))));
        case 214: // 0x19e1 cost=7
            return Expr::BitwiseNot(Expr::BitwiseXor(v(2), Expr::BitwiseXor(Expr::BitwiseOr(v(0), v(1)), Expr::BitwiseAnd(v(3), Expr::BitwiseOr(v(2), Expr::BitwiseAnd(v(0), v(1)))))));
        case 215: // 0x19e3 cost=7
            return Expr::BitwiseNot(Expr::BitwiseXor(v(2), Expr::BitwiseXor(Expr::BitwiseOr(v(1), Expr::BitwiseAnd(v(0), v(2))), Expr::BitwiseAnd(v(3), Expr::BitwiseOr(v(0), v(2))))));
        case 216: // 0x19e6 cost=4
            return Expr::BitwiseXor(v(3), Expr::BitwiseOr(Expr::BitwiseXor(v(0), v(1)), Expr::BitwiseAnd(v(0), v(2))));
        case 217: // 0x1bd8 cost=5
            return Expr::BitwiseXor(v(0), Expr::BitwiseXor(v(1), Expr::BitwiseOr(Expr::BitwiseXor(v(1), v(2)), Expr::BitwiseXor(v(0), v(3)))));
        case 218: // 0x1be4 cost=4
            return Expr::BitwiseXor(v(1), Expr::BitwiseXor(v(3), Expr::BitwiseAnd(v(0), Expr::BitwiseXor(v(1), v(2)))));
        case 219: // 0x1ee1 cost=4
            return Expr::BitwiseNot(Expr::BitwiseXor(v(2), Expr::BitwiseXor(v(3), Expr::BitwiseOr(v(0), v(1)))));
        case 220: // 0x3cc3 cost=3
            return Expr::BitwiseNot(Expr::BitwiseXor(v(1), Expr::BitwiseXor(v(2), v(3))));
        case 221: // 0x6996 cost=3
            return Expr::BitwiseXor(v(0), Expr::BitwiseXor(v(1), Expr::BitwiseXor(v(2), v(3))));
        default:
            return std::nullopt;
    }
}

// Collapse NOT(NOT(x)) -> x at all depths.
// NPN input/output negation can introduce double-NOTs
// when the canonical form already contains a NOT at the
// same position as the transform's negation.
void CollapseDoubleNot(std::unique_ptr<Expr> &expr) {
    for (auto &child : expr->children) {
        CollapseDoubleNot(child);
    }
    if (expr->kind == Expr::Kind::kNot &&
        !expr->children.empty() &&
        expr->children[0]->kind == Expr::Kind::kNot) {
        expr = std::move(expr->children[0]->children[0]);
    }
}

std::optional<std::unique_ptr<Expr>>
Match4varNpn(uint16_t key) {
    const auto &e = kNpn4Table[key];
    const auto *perm = kPerms4[e.perm_idx];

    // Inverse permutation
    uint32_t inv[4];
    for (uint32_t i = 0; i < 4; ++i) { inv[perm[i]] = i; }

    // Canonical var j -> actual Var(inv[j]),
    // negated if neg_inputs bit inv[j] is set.
    const uint8_t neg = e.neg_inputs;
    auto v = [&](uint32_t j) -> std::unique_ptr<Expr> {
        const uint32_t a = inv[j];
        auto expr = Expr::Variable(a);
        if ((neg >> a) & 1u) {
            return Expr::BitwiseNot(std::move(expr));
        }
        return expr;
    };

    auto result = BuildNpn4Canonical(e.class_id, v);
    if (!result) { return std::nullopt; }

    if (e.neg_output != 0u) {
        *result = Expr::BitwiseNot(std::move(*result));
    }
    CollapseDoubleNot(*result);
    return result;
}

